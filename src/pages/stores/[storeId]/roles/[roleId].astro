---
import StoreLayout from '../../../../layouts/StoreLayout.astro';
import RoleDetail from '../../../../components/roles/RoleDetail';
import { getDb } from '../../../../lib/db';

const { storeId, roleId } = Astro.params;
const db = getDb();

const storeResult = await db.execute({ sql: 'SELECT id, name FROM stores WHERE id = ?', args: [storeId ?? ''] });
const store = storeResult.rows[0] as { id: number; name: string } | undefined;
if (!store) return Astro.redirect('/stores');

const roleResult = await db.execute({ sql: 'SELECT id, name FROM roles WHERE id = ? AND store_id = ?', args: [roleId ?? '', storeId ?? ''] });
const role = roleResult.rows[0] as { id: number; name: string } | undefined;
if (!role) return Astro.redirect(`/stores/${storeId}/roles`);
---
<StoreLayout title={`${role.name} | ${store.name}`}>
  <nav class="flex items-center gap-2 text-sm text-gray-500 mb-6 flex-wrap">
    <a href="/stores" class="hover:text-[#16a085] transition-colors">Store Selection</a>
    <span>/</span>
    <a href={`/stores/${store.id}`} class="hover:text-[#16a085] transition-colors">{store.name}</a>
    <span>/</span>
    <a href={`/stores/${store.id}/roles`} class="hover:text-[#16a085] transition-colors">Role Management</a>
    <span>/</span>
    <span class="text-[#1a1a2e] font-medium">{role.name}</span>
  </nav>
  <div class="flex items-center gap-3 mb-6">
    <a href={`/stores/${store.id}/roles`} class="text-sm text-gray-400 hover:text-[#16a085] transition-colors">← Back</a>
    <h1 class="text-xl font-bold text-[#1a1a2e]">{role.name}</h1>
  </div>
  <RoleDetail storeId={store.id} roleId={role.id} client:load />
</StoreLayout>
